{
  "manifest_version": 3,
  "name": "OTIS — Counsellor Copilot",
  "version": "2.1.0",
  "description": "OTIS — Real-time AI copilot for Leap Scholar counsellors. Live transcription, script guidance, KB answers, and Notion sync.",
  "icons": {
    "16":  "icons/otis-16.png",
    "32":  "icons/otis-32.png",
    "48":  "icons/otis-48.png",
    "128": "icons/otis-128.png"
  },

  "permissions": [
    "tabCapture",
    "offscreen",
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],

  "web_accessible_resources": [{
    "resources": ["request-mic-permission.html", "request-mic-permission.js"],
    "matches": ["<all_urls>"]
  }],

  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:8000/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "OTIS — Counsellor Copilot",
    "default_icon": {
      "16":  "icons/otis-16.png",
      "32":  "icons/otis-32.png",
      "48":  "icons/otis-48.png",
      "128": "icons/otis-128.png"
    }
  }
}
