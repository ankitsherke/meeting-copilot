{
  "manifest_version": 3,
  "name": "Meeting Copilot",
  "version": "1.0.0",
  "description": "Real-time meeting assistant with RAG-powered suggestions",

  "permissions": [
    "tabCapture",
    "offscreen",
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],

  "web_accessible_resources": [{
    "resources": ["request-mic-permission.html", "request-mic-permission.js"],
    "matches": ["<all_urls>"]
  }],

  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:8000/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "Meeting Copilot"
  }
}
